  .trust-mini svg{width:16px; height:16px; stroke:var(--gold); flex:none;}
  .hero-img-wrap{position:relative; border-radius:6px; overflow:hidden;}
  .hero-img-wrap img{width:100%; aspect-ratio:5/4.4; object-fit:cover;}
  .hero-img-wrap::before{content:''; position:absolute; inset:0; background:linear-gradient(200deg, transparent 60%, rgba(11,11,12,0.5)); pointer-events:none;}

  /* ---------- why shop bar ---------- */
  .why-bar{background:var(--ink-2); color:var(--white); padding:34px 0;}
  .why-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:24px;}
  .why-item{display:flex; align-items:center; gap:14px;}
  .why-item svg{width:30px; height:30px; stroke:var(--gold); flex:none;}
  .why-item h4{font-size:14.5px; font-weight:600; margin-bottom:2px;}
  .why-item p{font-size:12px; color:#A9A69F; font-weight:300;}

  /* ---------- section shells ---------- */
  section{padding:80px 0;}
  .section-title{text-align:center; margin-bottom:44px;}
  .section-title .eyebrow-center{font-size:12px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:var(--gold-dark); margin-bottom:8px;}
  .section-title h2{font-size:clamp(24px,3.2vw,34px); color:var(--text-dark);}

  /* ---------- category tiles ---------- */
  .cat-grid{display:grid; grid-template-columns:repeat(5,1fr); gap:18px;}
  .cat-tile{position:relative; aspect-ratio:0.85/1; border-radius:6px; overflow:hidden; box-shadow:var(--shadow); cursor:pointer;}
  .cat-tile img{width:100%; height:100%; object-fit:cover; transition:transform 0.6s var(--ease), filter 0.5s;}
  .cat-tile:hover img{transform:scale(1.08); filter:brightness(0.65);}
  .cat-tile-overlay{position:absolute; inset:0; background:linear-gradient(to top, rgba(11,11,12,0.88), transparent 55%); display:flex; align-items:flex-end; padding:16px;}
  .cat-tile-overlay h4{color:var(--white); font-size:14px; margin-bottom:2px;}
  .cat-tile-overlay span{color:var(--gold-light); font-size:11px; font-weight:500;}

  /* ---------- product cards ---------- */
  .filters{display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:36px;}
  .filter-chip{padding:9px 20px; font-size:12.5px; font-weight:500; border:1.5px solid var(--line-light); border-radius:30px; color:var(--text-muted); transition:all 0.3s;}
