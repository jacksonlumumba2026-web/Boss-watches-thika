  .topbar-left span{display:flex; align-items:center; gap:6px;}
  .topbar-left svg{width:13px; height:13px; stroke:var(--gold); flex:none;}
  .topbar-social{display:flex; gap:12px;}
  .topbar-social a{width:26px; height:26px; border-radius:50%; border:1px solid rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; transition:border-color 0.3s, color 0.3s;}
  .topbar-social a:hover{border-color:var(--gold); color:var(--gold-light);}
  .topbar-social svg{width:12px; height:12px;}

