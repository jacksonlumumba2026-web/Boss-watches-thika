  .hero p.sub{color:#C9C6BE; font-size:15.5px; max-width:440px; margin-bottom:26px; font-weight:300;}
  .hero-actions{display:flex; gap:14px; margin-bottom:34px; flex-wrap:wrap;}
  .trust-mini-row{display:flex; gap:26px; flex-wrap:wrap;}
