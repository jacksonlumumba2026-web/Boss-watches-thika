  .mobile-nav a{font-size:17px; color:var(--white); font-weight:500;}

  /* ---------- hero ---------- */
  .hero{background:linear-gradient(120deg, #0B0B0C 55%, #141416 100%); color:var(--white); padding:64px 0 56px; position:relative; overflow:hidden;}
