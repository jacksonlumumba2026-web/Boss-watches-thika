  .brand-mark svg{width:100%; height:100%;}
  .brand small{display:block; font-size:9px; font-weight:400; color:var(--gold-light); letter-spacing:0.08em; font-family:'Inter',sans-serif;}

  nav.main-nav{display:flex; gap:30px;}
