  .btn-outline-light:hover{border-color:var(--gold); color:var(--gold-light);}
  .btn-outline-dark{border:1.5px solid rgba(0,0,0,0.15); color:var(--text-dark);}
  .btn-outline-dark:hover{border-color:var(--gold-dark); color:var(--gold-dark);}
  .btn-sm{padding:9px 16px; font-size:12.5px;}
  .btn-block{width:100%;}

  .menu-toggle{display:none; width:24px; height:18px; position:relative; flex:none;}
