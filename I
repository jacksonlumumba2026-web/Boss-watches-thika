<style>
  :root{
    --ink:#0B0B0C;
    --ink-2:#17171A;
    --paper:#FAFAF8;
    --paper-2:#F1EFE9;
    --text-dark:#1B1A18;
    --text-muted:#6E6B64;
    --white:#FFFFFF;
    --gold:#E0A526;
    --gold-dark:#B9860F;
    --gold-light:#F0D48A;
    --line-dark:rgba(255,255,255,0.12);
    --line-light:rgba(0,0,0,0.1);
    --shadow:0 24px 50px -16px rgba(0,0,0,0.18);
    --ease:cubic-bezier(.16,1,.3,1);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth; overflow-x:hidden; width:100%;}
  body{background:var(--paper); color:var(--text-dark); font-family:'Inter',sans-serif; font-weight:400; line-height:1.6; overflow-x:hidden; width:100%; max-width:100vw;}
  h1,h2,h3,h4{font-family:'Poppins',sans-serif; font-weight:700; letter-spacing:-0.01em;}
  .mono{font-family:'JetBrains Mono',monospace; letter-spacing:0.02em;}
  a{color:inherit; text-decoration:none;}
  ul{list-style:none;}
  img{max-width:100%; display:block;}
  button{font-family:inherit; cursor:pointer; border:none; background:none; color:inherit;}
  .wrap{max-width:1280px; margin:0 auto; padding:0 32px;}

  @media(prefers-reduced-motion: reduce){ *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;} }

  /* ---------- loading intro ---------- */
  #loadIntro{
    position:fixed; inset:0; background:var(--ink); z-index:5000;
    display:flex; align-items:center; justify-content:center; flex-direction:column; gap:18px;
    transition:opacity 0.6s var(--ease), visibility 0.6s;
  }
  #loadIntro.hide{opacity:0; visibility:hidden; pointer-events:none;}
  .intro-mark{width:96px; height:96px; position:relative; animation:pulse 1.3s ease-in-out infinite;}
  .intro-mark svg{width:100%; height:100%;}
  @keyframes pulse{0%,100%{transform:scale(1); opacity:1;} 50%{transform:scale(1.06); opacity:0.85;}}
  @keyframes spin{to{transform:rotate(360deg);}}
  .intro-text{font-family:'Poppins',sans-serif; font-weight:700; color:var(--gold-light); letter-spacing:0.08em; font-size:13px; text-transform:uppercase; opacity:0.9;}

  /* ---------- reveal ---------- */
  .reveal{opacity:0; transform:translateY(30px); transition:opacity 0.8s var(--ease), transform 0.8s var(--ease);}
  .reveal.in{opacity:1; transform:translateY(0);}

  /* ---------- top bar ---------- */
  .topbar{background:var(--ink); color:var(--paper); font-size:12.5px;}
  .topbar-inner{max-width:1280px; margin:0 auto; padding:9px 32px; display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap;}
