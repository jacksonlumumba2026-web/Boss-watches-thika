  .load-more-row{display:flex; justify-content:center; margin-top:36px;}
  .load-more-row.hide{display:none;}

  .search-bar{display:flex; align-items:center; gap:10px; padding:13px 20px; margin:0 auto 40px; border:1.5px solid var(--line-light); border-radius:30px; background:var(--white); max-width:420px;}
  .search-bar svg{width:16px; height:16px; stroke:var(--text-muted); flex:none;}
  .search-bar input{flex:1; background:none; border:none; font-size:14px; outline:none; color:var(--text-dark);}

  .product-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:26px;}
  .card{background:var(--white); border:1px solid var(--line-light); border-radius:6px; overflow:hidden; transition:transform 0.5s var(--ease), box-shadow 0.5s; position:relative;}
  .card:hover{transform:translateY(-6px); box-shadow:var(--shadow);}
  .card-img{aspect-ratio:1/0.92; overflow:hidden; position:relative; background:#EFEDE7;}
  .card-img img{width:100%; height:100%; object-fit:cover; transition:transform 0.6s var(--ease);}
  .card:hover .card-img img{transform:scale(1.06);}
  .card-tag{position:absolute; top:12px; left:12px; font-size:10px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; padding:5px 10px; background:var(--gold); color:var(--ink); border-radius:3px; z-index:2;}
  .wishlist-toggle{position:absolute; top:12px; right:12px; z-index:2; width:32px; height:32px; border-radius:50%; background:rgba(255,255,255,0.9); display:flex; align-items:center; justify-content:center; color:var(--text-dark); transition:all 0.3s;}
  .wishlist-toggle.active{color:var(--gold-dark);}
  .wishlist-toggle svg{width:15px; height:15px;}
  .card-body{padding:18px 18px 20px;}
  .card-ref{font-size:10.5px; color:var(--text-muted); margin-bottom:4px;}
  .card-name{font-size:15.5px; font-weight:600; margin-bottom:6px; cursor:pointer; color:var(--text-dark);}
  .card-rating{font-size:11.5px; color:var(--gold-dark); margin-bottom:10px;}
  .card-price{font-size:16px; font-weight:700; color:var(--text-dark); margin-bottom:12px;}
  .card-actions{display:flex; gap:8px;}
  .view-details-btn{flex:1; padding:10px 12px; font-size:12px; font-weight:600; letter-spacing:0.02em; background:var(--ink); color:var(--white); border-radius:3px; text-align:center; transition:background 0.3s;}
  .view-details-btn:hover{background:var(--gold-dark);}
  .cart-icon-btn{width:38px; height:38px; border-radius:3px; border:1.5px solid var(--line-light); display:flex; align-items:center; justify-content:center; transition:all 0.3s; flex:none;}
  .cart-icon-btn:hover{border-color:var(--gold-dark); color:var(--gold-dark);}
  .cart-icon-btn svg{width:16px; height:16px;}
  .empty-state{display:none; text-align:center; padding:50px 20px; color:var(--text-muted); grid-column:1/-1;}
  .empty-state.show{display:block;}

  /* ---------- about ---------- */
  .about-section{
    background:
      linear-gradient(120deg, rgba(11,11,12,0.94), rgba(11,11,12,0.88)),
      url(data:image/jpeg;base64,
